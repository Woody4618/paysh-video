# Copy to .env.local for local dev, or set these as Vercel project env vars.
#
# Locally, source this before starting the gateway so pay can expand ${VAR}:
#   set -a; . ./.env.local; set +a
#   pay server start provider.yml

# Shared secret the gateway injects and /api/forecast validates. Generate one:
#   openssl rand -hex 32
# The pay gateway (provider.yml routing.auth.value_from_env) and the Next.js
# route (app/api/forecast/route.ts) MUST use the same value.
GATEWAY_SHARED_SECRET=

# Where the gateway forwards paid requests. This is the app's own origin.
#   local dev:  http://localhost:3000
#   production: https://your-app.vercel.app
UPSTREAM_ORIGIN=http://localhost:3000

# --- pay gateway (mainnet) env, expanded into provider.yml ---
# Solana RPC endpoint used for payment verification / fee sponsorship.
PAY_RPC_URL=
# Wallet that receives the payments (base58 pubkey).
PAY_PAYMENT_RECIPIENT=
# Fee-payer keypair the gateway signs with. Solana CLI JSON array (64 bytes)
# or a base58 secret key. HOT WALLET — keep only small balances here.
# Get the JSON from an existing keypair file:  cat ~/.config/solana/id.json
PAY_OPERATOR_KEYPAIR=
