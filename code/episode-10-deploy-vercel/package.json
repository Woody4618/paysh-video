{
  "name": "weather-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "openapi": "openapi-gen generate",
    "openapi:watch": "openapi-gen generate --watch",
    "openapi:snapshot": "openapi-gen generate && node scripts/snapshot-catalog-openapi.mjs",
    "prebuild": "openapi-gen generate",
    "build": "next build",
    "start": "next start",
    "gateway:build": "docker build -f Dockerfile.vercel -t weather-pro-gateway:local .",
    "gateway": "docker run --rm -p 1402:1402 --env-file .env.local -e PORT=1402 -e UPSTREAM_ORIGIN=http://host.docker.internal:3000 weather-pro-gateway:local"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next-openapi-gen": "^1.6.0",
    "typescript": "^5.6.0"
  }
}
