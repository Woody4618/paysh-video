{
  "openapi": "3.1.0",
  "info": {
    "title": "Production Gateway",
    "version": "v1",
    "description": "Normalized usage reports for analytics and billing automation."
  },
  "servers": [{ "url": "https://prod-gateway.example.com" }],
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "health",
        "summary": "Check gateway health and readiness status",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/reports/usage": {
      "get": {
        "operationId": "getUsageReport",
        "summary": "Fetch usage report for a time range",
        "x-pay-pricing": {
          "dimensions": [
            {
              "direction": "usage",
              "unit": "requests",
              "scale": 1,
              "tiers": [{ "price_usd": 0.01 }]
            }
          ]
        },
        "responses": { "200": { "description": "Usage report" } }
      }
    }
  }
}
